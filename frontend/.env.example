# Backend WebSocket/API URL (set to your Railway URL after deploying)
VITE_SOCKET_URL=https://your-backend.up.railway.app

# Mapbox public token
VITE_MAPBOX_TOKEN=pk.eyJ1Ijoibmd1c2h3YWkiLCJhIjoiY21wempsY2tuMDJ3ZjJzcjMxdXl0dzRoeiJ9.mdf2eIbYpquNdhM1sHUfEA

# Firebase Realtime Database (for live ESP32 GPS tracking)
# Get these from: Firebase Console → Project Settings → Your Apps → SDK Config
# Leave VITE_FIREBASE_DATABASE_URL blank to run in simulation-only mode.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ESP32 writes to Firebase path: dart-buses/{busId}
# Example: dart-buses/DART001 → { latitude, longitude, speed, heading, timestamp }
